{
  "name": "fairgig-grievance-service",
  "version": "1.0.0",
  "description": "FairGig standalone grievance service — complaint CRUD, tagging, escalation, advocate moderation",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "pnpm db:generate",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "hono": "^4.4.0",
    "@prisma/client": "^5.22.0",
    "zod": "^3.23.0",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
