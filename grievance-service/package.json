{
  "name": "fairgig-grievance-service",
  "version": "1.0.0",
  "description": "FairGig standalone grievance service — complaint CRUD, tagging, escalation, advocate moderation",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "pnpm db:generate",
    "db:generate": "pnpm dlx prisma@7.7.0 generate --schema=prisma/schema.prisma",
    "db:push": "pnpm dlx prisma@7.7.0 db push --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@prisma/client-runtime-utils": "7.7.0",
    "dotenv": "^16.4.0",
    "hono": "^4.4.0",
    "pg": "^8.16.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "prisma": "^7.7.0"
  }
}